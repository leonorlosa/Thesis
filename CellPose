import numpy as np
import matplotlib.pyplot as plt
import imageio.v3 as iio
from cellpose import models, io as cellpose_io, plot, utils
import torch
import os
from skimage.filters import gaussian
import traceback
import time
from matplotlib.widgets import Button # Import Button widget
import tifffile as tiff 


image_folder = "segmentation/IC50 segmentation" 
diameter = 150 
model_type = 'cyto2'
channels = [0, 0] 
force_cpu = False
use_gaussian_blur = True
blur_sigma = 1.8


# Check for GPU availability
use_gpu = not force_cpu and torch.cuda.is_available()
print(f">>> Using GPU: {use_gpu}")
if use_gpu:
    try:
        gpu_name = torch.cuda.get_device_name(0)
        print(f">>> Found GPU: {gpu_name}")
    except Exception as e:
        print(f">>> GPU found, but could not get device name: {e}")
else:
    print(">>> Using CPU.")


print(f">>> Initializing Cellpose model ('{model_type}')...")
try:
    model = models.Cellpose(gpu=use_gpu, model_type=model_type)
    print(">>> Cellpose model initialized.")
except Exception as e:
    print(f"!!! Error initializing Cellpose model: {e}")
    print("!!! Please check your Cellpose installation.")
    traceback.print_exc()
    exit()



def interactive_segmentation_review_with_buttons(img, masks, image_name):
    """
    Displays segmentation results and allows user to edit masks using buttons.
    - Click on masks to select/deselect them (yellow outline).
    - Click 'Delete Selected' button: Remove all selected masks.
    - Click 'Merge Selected' button: Merge exactly 2 selected masks.
    - Close window: Exit review and return modified masks.

    Returns the modified masks array.
    """
   
    editable_masks = masks.copy()
    print(f"\n--- Interactive review for '{image_name}' ---")
    print("--- Click on masks to select/deselect (yellow outline) ---")
    print("--- Use buttons for Delete/Merge ---")
    print("--- Close window when done ---")

    
    initial_n_cells = len(np.unique(editable_masks[editable_masks > 0]))
    print(f"--- Objects found initially: {initial_n_cells} ---")

    
    fig = plt.figure(figsize=(15, 8))
    plot_ax = fig.add_axes([0.05, 0.20, 0.9, 0.75]) 
    button_ax_delete = fig.add_axes([0.3, 0.05, 0.15, 0.07])
    button_ax_merge = fig.add_axes([0.55, 0.05, 0.15, 0.07])

    
    plot_ax.imshow(img, cmap='gray')
    plot_ax.set_title(f"Edit Segmentation: {image_name} (Click masks to select)")
    plot_ax.axis('off')

   
    outlines = utils.masks_to_outlines(editable_masks)
    outline_contour_set = plot_ax.contour(outlines, colors='darkgreen', linewidths=1.5)

    
    selected_cell_ids = [] # List to store IDs of currently selected cells
    selection_highlight_collections = []

    
    def update_selection_highlights():
        nonlocal selection_highlight_collections 

       
        for collection in selection_highlight_collections:
            collection.remove()
        selection_highlight_collections = [] 

       
        temp_collections = [] # Temporary list to gather new collections
        for cell_id in selected_cell_ids:
            if cell_id > 0: # Ensure it's a valid ID
                # Get outline for this specific cell
                highlight_outline = utils.masks_to_outlines(editable_masks == cell_id)
                # Generate the new contour set for this single cell
                contour_set = plot_ax.contour(highlight_outline, colors='yellow', linewidths=2.5)

                # Add all PathCollection objects from this contour set to our temp list
                # Check if 'collections' attribute exists and is not empty
                if hasattr(contour_set, 'collections') and contour_set.collections:
                    temp_collections.extend(contour_set.collections)
                # else:
                    # Optional: print a warning if collections are missing/empty, though often expected if a mask is tiny/gone
                    # print(f"Warning: No highlight collections found for ID {cell_id}")

       
        selection_highlight_collections = temp_collections

        fig.canvas.draw_idle() # Update the display


   
    def update_main_plot():
        nonlocal outline_contour_set 

        if outline_contour_set and hasattr(outline_contour_set, 'collections'):
            for collection in outline_contour_set.collections:
                collection.remove()
       

       
        new_outlines = utils.masks_to_outlines(editable_masks)
        outline_contour_set = plot_ax.contour(new_outlines, colors='darkgreen', linewidths=1.5)

       
        current_n_cells = len(np.unique(editable_masks[editable_masks > 0]))
        plot_ax.set_title(f"Edit Segmentation: {image_name} ({current_n_cells} objects) - Click masks to select")

        fig.canvas.draw_idle() # Update the display


    def on_click(event):
        nonlocal selected_cell_ids

        if event.inaxes != plot_ax or event.button != 1:
            return

        if event.xdata is None or event.ydata is None:
            return

        y, x = int(event.ydata), int(event.xdata)
        if not (0 <= y < editable_masks.shape[0] and 0 <= x < editable_masks.shape[1]):
            return

        clicked_cell_id = editable_masks[y, x]

      
        clicked_cell_id = int(clicked_cell_id)

        if clicked_cell_id > 0:
            if clicked_cell_id in selected_cell_ids:
                selected_cell_ids.remove(clicked_cell_id)
                print(f"--- Deselected object ID: {clicked_cell_id}. Selected: {selected_cell_ids} ---")
            else:
                selected_cell_ids.append(clicked_cell_id)
                print(f"--- Selected object ID: {clicked_cell_id}. Selected: {selected_cell_ids} ---")
            update_selection_highlights()
        else:
            if selected_cell_ids:
                print("--- Clicked background. Clearing selection. ---")
                selected_cell_ids = []
                update_selection_highlights()


    
    def delete_selected(event):
        nonlocal editable_masks, selected_cell_ids

        if not selected_cell_ids:
            print("--- No cells selected to delete. ---")
            return

        print(f"--- Deleting selected objects: {selected_cell_ids} ---")
        deleted_count = 0
        for cell_id in selected_cell_ids:
            if cell_id > 0:
                mask_pixels = (editable_masks == cell_id)
                if np.any(mask_pixels): # Check if the mask still exists
                    editable_masks[mask_pixels] = 0
                    deleted_count += 1

        print(f"--- {deleted_count} selected masks deleted. ---")
     
        selected_cell_ids = []
        update_selection_highlights() # Remove highlights
        update_main_plot() # Update the main plot to show changes


   
    def merge_selected(event):
        nonlocal editable_masks, selected_cell_ids

        if len(selected_cell_ids) != 2:
            print("--- Select exactly 2 cells to merge. ---")
            return

        id1 = int(selected_cell_ids[0])
        id2 = int(selected_cell_ids[1])

        print(f"--- Merging objects {id1} and {id2} ---")

        target_id = min(id1, id2)
        source_id = max(id1, id2)

        source_pixels = (editable_masks == source_id)

        if np.any(source_pixels): # Check if the source mask still exists
            # Change all pixels of the source ID to the target ID
            editable_masks[source_pixels] = target_id
            print(f"--- Changed pixels from {source_id} to {target_id}. ---")
        else:
            print(f"--- Warning: Mask for source ID {source_id} not found (might have been deleted?). Merge aborted for this ID pair. ---")


       
        selected_cell_ids = []
        update_selection_highlights() # Remove highlights
        update_main_plot() # Update the main plot to show changes
        if np.any(source_pixels): # Only print success if merge happened
             print("--- Selected masks merged. ---")


   
    btn_delete = Button(button_ax_delete, 'Delete Selected')
    btn_merge = Button(button_ax_merge, 'Merge Selected')


    btn_delete.on_clicked(delete_selected)
    btn_merge.on_clicked(merge_selected)

   
    cid = fig.canvas.mpl_connect('button_press_event', on_click)

   
    try:
        fig.tight_layout(rect=[0, 0.1, 1, 1]) # Adjust rect to prevent overlap with buttons
    except Exception:
         print("--- Could not apply tight_layout. Spacing might be suboptimal. ---")

    plt.show(block=True) # Halts execution until the figure window is closed

   
    fig.canvas.mpl_disconnect(cid)
    plt.close(fig) # Explicitly close the figure


    unique_ids = np.unique(editable_masks)
    unique_ids = unique_ids[unique_ids > 0] # Exclude background
    final_masks = np.zeros_like(editable_masks)
    for i, old_id in enumerate(unique_ids):
        final_masks[editable_masks == old_id] = i + 1 

   
    return final_masks


print(f">>> Processing images in folder: {image_folder}")

try:
    image_files = [f for f in os.listdir(image_folder) if f.lower().endswith(('.tiff', '.tif'))]
    if not image_files:
        print(f"!!! Warning: No '.tif' or '.tiff' files found in the folder: {image_folder}")
    print(f">>> Found {len(image_files)} image files: {image_files}")
except FileNotFoundError:
    print(f"!!! Error: Folder not found at {image_folder}")
    traceback.print_exc()
    image_files = []
except Exception as e:
    print(f"!!! Error accessing folder: {e}")
    traceback.print_exc()
    image_files = []


if not image_files:
     print("--- No images to process. Exiting. ---")
     exit()

output_mask_folder = os.path.join(image_folder, "modified_masks")
try:
    os.makedirs(output_mask_folder, exist_ok=True)
    print(f">>> Modified masks will be saved to: {output_mask_folder}")
except Exception as e:
    print(f"!!! Error creating output folder {output_mask_folder}: {e}")
    traceback.print_exc()
    output_mask_folder = image_folder # Fallback


for image_name in image_files:
    image_path = os.path.join(image_folder, image_name)
    print(f"\n>>> Processing image: {image_name}")

    try:
        img = iio.imread(image_path)
     
        print(f"--- Original image shape: {img.shape}")
        if img.ndim == 2:
            pass # Already 2D
        elif img.ndim == 3:
            # Check common formats (H, W, C) or (C, H, W)
            if img.shape[-1] in [1, 3, 4]: # Likely (H, W, C)
                if img.shape[-1] == 1: # (H, W, 1) -> (H, W)
                    img = img[..., 0]
                else: # (H, W, 3) or (H, W, 4) -> Grayscale (H, W)
                    print("--- Converting color image to grayscale (averaging RGB).")
                    img = np.mean(img[..., :3], axis=-1)
            elif img.shape[0] in [1, 3, 4]: # Likely (C, H, W)
                if img.shape[0] == 1: # (1, H, W) -> (H, W)
                    img = img[0, :, :]
                else: # (3, H, W) or (4, H, W) -> Grayscale (H, W)
                    print("--- Converting color image to grayscale (averaging RGB).")
                    img = np.mean(img[:3, ...], axis=0)
            else: 
                 print(f"--- Warning: 3D image of shape {img.shape} is not standard C,H,W or H,W,C. Taking first slice (index 0).")
                 img = img[0, :, :]
        elif img.ndim > 3:
            print(f"--- Warning: Image has {img.ndim} dimensions ({img.shape}). Attempting to squeeze and take first 2D slice.")
            img_squeezed = np.squeeze(img)
            if img_squeezed.ndim >= 2:
                # Take the first 2D slice (e.g., [0,0,:,:] for 4D)
                slice_indices = tuple([0] * (img_squeezed.ndim - 2))
                img = img_squeezed[slice_indices]
                print(f"--- Squeezed and took slice {slice_indices}. Resulting shape: {img.shape}")
            else:
                 raise ValueError(f"Cannot reduce image '{image_name}' with shape {img.shape} to 2D.")
        else: # ndim < 2
            raise ValueError(f"Image '{image_name}' has unsupported dimensions: {img.shape}")

        if img.ndim != 2:
            raise ValueError(f"Loaded image '{image_name}' could not be converted to 2D (final shape: {img.shape}).")

        print("--- Image loaded successfully. Final Shape:", img.shape)

        img_min = np.min(img)
        img_max = np.max(img)
        if img_max > img_min:
             img = (img - img_min) / (img_max - img_min) # Normalize to 0-1
             img = img.astype(np.float32)
        else: # Handle case of a constant image
             img = img.astype(np.float32)

        if use_gaussian_blur:
            print(f"--- Applying Gaussian blur with sigma: {blur_sigma}")
            # Ensure sigma is reasonable compared to image size if needed
            img = gaussian(img, sigma=blur_sigma, preserve_range=True) # Preserve float range

    except FileNotFoundError:
        print(f"!!! Error: Image file not found at {image_path}")
        continue
    except ValueError as ve:
         print(f"!!! Error processing image dimensions for '{image_name}': {ve}")
         traceback.print_exc()
         continue
    except Exception as e:
        print(f"!!! Error loading or pre-processing image '{image_name}': {e}")
        traceback.print_exc()
        continue

    print(f">>> Running segmentation for '{image_name}' (diameter={diameter if diameter is not None else 'auto-detect'})...")
    masks = None
    try:
        try:
            masks, flows, styles, diams = model.eval(img, # Use the preprocessed float32 img
                                                   diameter=diameter,
                                                   channels=channels,
                                                   flow_threshold=0.4,
                                                   cellprob_threshold=0.0,
                                                   min_size=15,
                                                   do_3D=False) # Explicitly False for 2D
        except Exception as cellpose_eval_error:
             print(f"!!! Error during Cellpose model.eval for '{image_name}': {cellpose_eval_error}")
             print("!!! Skipping interactive review and saving empty mask for this image.")
             traceback.print_exc()
             masks = np.zeros(img.shape, dtype=np.uint16) # Use image shape after potential slicing


        if masks is not None:
            n_cells_initial = len(np.unique(masks[masks > 0]))
            print(f">>> Segmentation complete for '{image_name}'. Found {n_cells_initial} potential cells/objects.")
            if diameter is None and 'diams' in locals() and diams is not None:
                 print(f"--- Cellpose estimated diameter: {diams:.2f} pixels")

            reviewed_masks = interactive_segmentation_review_with_buttons(img, masks, image_name)

            n_cells_reviewed = len(np.unique(reviewed_masks[reviewed_masks > 0]))
            print(f">>> Final object count after review and renumbering: {n_cells_reviewed}.")
            if n_cells_reviewed > 0:
                print(">>> Displaying final segmentation results (non-blocking). Close the window to dismiss.")
                final_fig, final_ax = plt.subplots(1, 1, figsize=(8, 8))
                final_ax.imshow(img, cmap='gray') # Plot normalized original image
                final_outlines = utils.masks_to_outlines(reviewed_masks)
                final_ax.contour(final_outlines, colors='yellow', linewidths=1.5)
                final_ax.set_title(f"Final Segmentation: {image_name} ({n_cells_reviewed} objects)")
                final_ax.axis('off')
                plt.tight_layout()
                plt.show(block=False)
                plt.pause(0.1) # Allow rendering time
            else:
                print("--- No objects remaining after review, no final plot displayed. ---")


            print(f">>> Saving modified mask for '{image_name}'...")
            base_name = os.path.splitext(image_name)[0]

            output_raw_mask_name = f"{base_name}_modified_mask_renumbered.tif"
            output_raw_mask_path = os.path.join(output_mask_folder, output_raw_mask_name)
            try:
                tiff.imwrite(output_raw_mask_path, reviewed_masks.astype(np.uint16))
                print(f"--- Modified mask (renumbered IDs) saved to: {output_raw_mask_path}")
            except Exception as e:
                print(f"!!! Error saving renumbered mask TIFF for '{image_name}': {e}")
                traceback.print_exc()


            output_mask_vis_name = f"{base_name}_modified_mask_vis.png"
            output_mask_vis_path = os.path.join(output_mask_folder, output_mask_vis_name)
            try:
                # Use cellpose plotting function for a nice colored visualization
                # Generate an RGB image overlaying masks on the original grayscale image
                img_for_plot = img.copy()
                # Scale 0-1 float image back to uint8 for plotting overlay if desired
                if np.nanmax(img_for_plot) <= 1.0 and np.nanmin(img_for_plot) >= 0.0:
                     img_for_plot = (img_for_plot * 255).astype(np.uint8)

             
                if img_for_plot.ndim == 2:
                    img_rgb = np.stack((img_for_plot,)*3, axis=-1)
                else: # Should already be uint8 grayscale here, make it RGB
                    img_rgb = img_for_plot

                mask_rgb = plot.mask_overlay(img_rgb, reviewed_masks) # Use renumbered masks

                iio.imwrite(output_mask_vis_path, mask_rgb)
                print(f"--- Modified mask (color overlay visualization) saved to: {output_mask_vis_path}")

            except Exception as e:
                print(f"!!! Error saving visualization overlay PNG for '{image_name}': {e}")
                traceback.print_exc()

            time.sleep(0.1)


    except Exception as e:
        print(f"!!! Unhandled error during processing loop for '{image_name}': {e}")
        traceback.print_exc()


print("\n>>> Finished processing all images in the folder.")
